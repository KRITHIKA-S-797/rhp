#include<iostream>
using namespace std;
int main(){
    string str;
    cin>>str;
    int l=str.length();
    for(int i=0;i<(1<<l);i++){
        string result="";
        for(int j=0;j<10;j++){
            if((i&(1<<j))>0){
                result +=str[j];
            }
        }
        cout<<result<<endl;
    }
}
